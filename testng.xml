<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="DemoWebShop Full Automation Suite" parallel="false">

    <listeners>
        <listener class-name="reporting.ExtentReportListener"/>
    </listeners>

    <!-- Page-Object-based tests: registration, login, cart -->
    <test name="POM Cart and Auth Tests">
        <classes>
            <class name="tests.AuthenticationTest"/>
            <class name="tests.CartOperationsTest"/>
            <class name="tests.MultiProductCartTest"/>
        </classes>
    </test>

    <!-- Self-contained tests: navigation, profile, wishlist -->
    <test name="Standalone Tests">
        <classes>
            <class name="standalone.CategoriesNavigationTest"/>
            <class name="standalone.UserProfileAddressesTest"/>
            <class name="standalone.WishlistComparisonsTest"/>
        </classes>
    </test>

    <!-- Brave-browser checkout tests: require Brave installed at the hardcoded path -->
    <test name="Checkout Tests (Brave only)">
        <classes>
            <class name="checkout.TestCheckoutFlow"/>
            <class name="checkout.TestCheckoutValidation"/>
            <class name="checkout.TestCreditCardCheckout"/>
            <class name="checkout.TestRegisteredCheckout"/>
        </classes>
    </test>

</suite>
